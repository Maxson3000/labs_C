#include <stdio.h>
#include <ctype.h>

int main() {
    char expr[256];
    printf("Введите выражение: ");
    fgets(expr, sizeof(expr), stdin);

    double result = 0.0;   // итоговый результат
    double current = 0.0;  // текущее число
    char op = '+';         // текущий оператор, по умолчанию +
    int i = 0;             // индекс в строке
    int has_dot = 0;       // флаг: встретили точку?
    double dot_div = 1.0;  // делитель для дробной части

    while (expr[i] != '\0' && expr[i] != '\n') {
        if (expr[i] == ' ') {
            i++;
            continue;
        }

        // Если встретили оператор
        if (expr[i] == '+' || expr[i] == '-') {
            // Применяем предыдущий оператор к накопленному числу
            if (op == '+') result += current;
            else          result -= current;

            // Запоминаем новый оператор и сбрасываем число
            op = expr[i];
            current = 0.0;
            has_dot = 0;
            dot_div = 1.0;
            i++;
            continue;
        }

        // Если встретили точку
        if (expr[i] == '.') {
            has_dot = 1;
            i++;
            continue;
        }

        // Если цифра
        if (isdigit(expr[i])) {
            int digit = expr[i] - '0';

            if (!has_dot) {
                // Целая часть
                current = current * 10.0 + digit;
            } else {
                // Дробная часть
                dot_div *= 10.0;
                current = current + (double)digit / dot_div;
            }
            i++;
            continue;
        }

        // Неизвестный символ — пропускаем
        i++;
    }

    // Применяем последний оператор к последнему числу
    if (op == '+') result += current;
    else          result -= current;

    printf("Результат: %g\n", result);
    return 0;
}
