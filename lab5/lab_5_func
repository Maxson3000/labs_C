#include "func.h"
#include <stdlib.h>

double* calculate_matrix(double* matrix1, double* matrix2, int n, char op) {
    double* result = (double*)malloc(n * n * sizeof(double));
    
    switch(op) {
        case '+':
            for(int i = 0; i < n * n; i++) {
                result[i] = matrix1[i] + matrix2[i];
            }
            break;
        case '-':
            for(int i = 0; i < n * n; i++) {
                result[i] = matrix1[i] - matrix2[i];
            }
            break;
        case '*':
            for(int i = 0; i < n; i++) {
                for(int j = 0; j < n; j++) {
                    result[i * n + j] = 0;
                    for(int k = 0; k < n; k++) {
                        result[i * n + j] += matrix1[i * n + k] * matrix2[k * n + j];
                    }
                }
            }
            break;
    }
    
    return result;
}