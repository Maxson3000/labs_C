#include "mymath.h"
#include <stdarg.h>

// Сумма
double sum(int count, ...)
{
    va_list list;
    va_start(list, count);
    
    double result = 0;
    for (int i = 0; i < count; i++)
    {
        result = result + va_arg(list, double);
    }
    
    va_end(list);
    return result;
}

// Максимум
double max(int count, ...)
{
    va_list list;
    va_start(list, count);
    
    double result = va_arg(list, double);  // берём первый
    
    for (int i = 1; i < count; i++)
    {
        double x = va_arg(list, double);
        if (x > result)
            result = x;
    }
    
    va_end(list);
    return result;
}

// Минимум
double min(int count, ...)
{
    va_list list;
    va_start(list, count);
    
    double result = va_arg(list, double);  // берём первый
    
    for (int i = 1; i < count; i++)
    {
        double x = va_arg(list, double);
        if (x < result)
            result = x;
    }
    
    va_end(list);
    return result;
}

// Среднее арифметическое
double average(int count, ...)
{
    va_list list;
    va_start(list, count);
    
    double total = 0;
    for (int i = 0; i < count; i++)
    {
        total = total + va_arg(list, double);
    }
    
    va_end(list);
    return total / count;
}
