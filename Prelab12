#include <stdio.h>
#include <time.h>
#include <string.h>
char *wday_names[] = {"Вс", "Пн", "Вт", "Ср", "Чт", "Пт", "сб"};
char *month_names[] = {
    "январь", "февраль", "мрт", "апрель",
    "май", "июнь", "июль", "август",
    "сентябрь", "октябрь", "ноябрь", "декабрь"
};
int days_in_month[] = {31, 28, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31};
int is_leap(int year)
{
    if (year % 400 == 0) return 1;
    if (year % 100 == 0) return 0;
    if (year % 4 == 0) return 1;
    return 0;
}
int get_days(int year, int month)
{
    int days = days_in_month[month - 1];
    if (month == 2 && is_leap(year))
        days = 29;
    return days;
}

// Вывести день недели для даты гггг.мм.дд
void show_weekday(int year, int month, int day)
{
    struct tm t = {0};
    t.tm_year = year - 1900;
    t.tm_mon = month - 1;
    t.tm_mday = day;
    
    mktime(&t);
    
    printf("%s\n", wday_names[t.tm_wday]);
}

// Вывести календарь на месяц
void show_month(int year, int month)
{
    struct tm t = {0};
    t.tm_year = year - 1900;
    t.tm_mon = month - 1;
    t.tm_mday = 1;
    
    mktime(&t);
    int first_wday = t.tm_wday;  // день недели 1-го числа
    
    int days = get_days(year, month);
    printf("\n%s %d\n", month_names[month - 1], year);
    printf("Пн Вт Ср Чт Пт Сб Вс\n");
    // Если воскресенье отступ 6 пробельных позиций
    // Если понедельник отступ 0
    int offset;
    if (first_wday == 0)
        offset = 6;  // воскресенье
    else
        offset = first_wday - 1;  // пн=0, вт=1, ..., сб=5
    
    for (int i = 0; i < offset; i++)
        printf("   ");
    
    // Вывод чисел
    for (int d = 1; d <= days; d++)
    {
        printf("%2d ", d);
        
        // После субботы — новая строка
        if ((d + offset) % 7 == 0)
            printf("\n");
    }
    printf("\n");
}

// Вывести календарь на год
void show_year(int year)
{
    for (int m = 1; m <= 12; m++)
    {
        show_month(year, m);
    }
}

// Вывести текущую дату
void show_now()
{
    time_t t = time(NULL);
    struct tm *p = localtime(&t);
    
    printf("%04d.%02d.%02d\n",
           p->tm_year + 1900,
           p->tm_mon + 1,
           p->tm_mday);
}

int main()
{
    char input[100];
    
    printf("Введите дату (гггг.мм.дд, гггг.мм, гггг или now):\n");
    scanf("%s", input);
    
    int year, month, day;
    int count = sscanf(input, "%d.%d.%d", &year, &month, &day);
    
    if (count == 3)
    {
        // гггг.мм.дд
        show_weekday(year, month, day);
    }
    else if (count == 2)
    {
        // гггг.мм
        show_month(year, month);
    }
    else if (count == 1)
    {
        // гггг
        show_year(year);
    }
    else if (strcmp(input, "now") == 0)
    {
        show_now();
}
